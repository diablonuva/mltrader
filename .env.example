# Alpaca broker credentials
# Paper trading:  https://paper-api.alpaca.markets
# Live trading:   https://api.alpaca.markets  (requires funded account)
ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# SMTP — required for performance report emails
# Gmail: Google Account → Security → 2-Step Verification → App Passwords
# Generate a 16-char App Password (spaces are optional but kept for readability)
SMTP_USER=your_gmail@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
